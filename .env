# ================================================
# 服务配置
# ================================================
PORT=3080
# HOST=0.0.0.0
# LOG_LEVEL=INFO

# ================================================
# CodeBuddy 配置
# ================================================
# 区域: cn (默认，国内站) 或 intl (国际站)
# CODEBUDDY_REGION=cn

# 旧凭证无 base_url 时的兜底上游地址（一般无需配置）
# CODEBUDDY_DEFAULT_BASE_URL=https://copilot.tencent.com

# 企业站地址，多个用逗号分隔，会追加到管理面板的上游下拉列表
# CODEBUDDY_EXTRA_BASE_URLS=https://your-company.copilot.tencent.com

# 凭证存储目录
# CODEBUDDY_CREDS_DIR=.codebuddy

# ================================================
# Relay 配置
# ================================================
# 凭证存储目录
# RELAY_CREDS_DIR=.relay
