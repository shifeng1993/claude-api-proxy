# ================================================
# 代理配置
# ================================================
# 用于访问 Claude 模型，设置你的节点代理地址
# 常见代理软件配置:
# Clash:       http://127.0.0.1:7890
# V2rayN:      http://127.0.0.1:10809
# Shadowsocks: socks5://127.0.0.1:1080
# Clash Verge: http://127.0.0.1:7891
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# ================================================
# 服务配置
# ================================================
PORT=3080
HOST=0.0.0.0

# ================================================
# CodeBuddy 配置
# ================================================
# CodeBuddy 凭证存储目录
# CODEBUDDY_CREDS_DIR=.codebuddy

# CodeBuddy 默认上游 URL
# 国内站: https://copilot.tencent.com
# 国际站: https://www.codebuddy.ai
# CODEBUDDY_DEFAULT_BASE_URL=https://copilot.tencent.com

# CodeBuddy 区域: cn (默认, 使用国内站) 或 intl (使用国际站)
# CODEBUDDY_REGION=cn

# ================================================
# Relay 配置
# ================================================
# Relay 凭证存储目录
# RELAY_CREDS_DIR=.relay
