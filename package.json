{
    "name": "claude-api-proxy",
    "version": "1.0.0",
    "description": "Claude API 代理服务 - 将 Claude API 请求转换为 OpenAI 格式",
    "type": "module",
    "main": "src/index.js",
    "scripts": {
        "start": "node --use-system-ca src/index.js",
        "debug": "cross-env LOG_LEVEL=DEBUG node --use-system-ca src/index.js",
        "dev": "node --use-system-ca --watch src/index.js",
        "test": "node --test tests/*.test.js"
    },
    "dependencies": {
        "@tencent-ai/codebuddy-code": "^2.98.1",
        "busboy": "^1.6.0",
        "cross-env": "^7.0.3",
        "dotenv": "^17.2.4",
        "html2canvas": "^1.4.1",
        "https-proxy-agent": "^7.0.6",
        "jsonwebtoken": "^9.0.3",
        "jspdf": "^2.5.2",
        "ldapjs": "^3.0.7",
        "mysql2": "^3.22.3",
        "sequelize": "^6.37.8",
        "socks-proxy-agent": "^8.0.5",
        "ws": "^8.21.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "claude",
        "claude code",
        "claude-code-router",
        "openai",
        "api",
        "proxy"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "node-ssh": "^13.2.1"
    }
}
