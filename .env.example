# ================================================
# Service
# ================================================
PORT=3080
HOST=0.0.0.0
# LOG_LEVEL=INFO

# ================================================
# Session
# ================================================
# Required in production. Use a long random value.
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRES_IN=8h

# ================================================
# Database
# ================================================
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>
DB_NAME=claude_api_proxy

# ================================================
# Authentication
# ================================================
# Local auth is used when LDAP is missing or unreachable.
LOCAL_ADMIN_USER=admin
LOCAL_ADMIN_PASSWORD=changeme123

# LDAP auth is selected at startup only when all required LDAP vars are set
# and the LDAP server is reachable.
# LDAP_SERVER=ldap://ldap.example.com:389
# LDAP_BIND_DN=<ldap-bind-account>
# LDAP_BIND_PASSWORD=<ldap-bind-password>
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_FILTER=(sAMAccountName={userNo})
# LDAP_PROBE_TIMEOUT_MS=3000

# Keep Relay API auth enabled by default.
LDAP_RELAY_ENABLED=true

# ================================================
# CodeBuddy
# ================================================
# cn or intl
# CODEBUDDY_REGION=cn
# CODEBUDDY_DEFAULT_BASE_URL=https://codebuddy.example.com
# Labels shown for non-official/custom CodeBuddy upstreams in the console, keyed by host or full URL.
# CODEBUDDY_CUSTOM_SITE_LABELS={"ai-coding.example.com":"自定义站"}
# Comma separated extra upstream base URLs shown in the console.
# CODEBUDDY_EXTRA_BASE_URLS=https://codebuddy.example.com,https://ai-coding.example.com
# Optional model list overrides by host or full URL.
# CODEBUDDY_MODEL_OVERRIDES={"ai-coding.example.com":[{"id":"custom:glm51","name":"GLM-5.1","tools":true,"vision":false}]}
# CODEBUDDY_DEFAULT_USER_ID=unknown

# ================================================
# Stats / feedback access filters
# Empty means no IP whitelist.
# ================================================
# STATS_IP_WHITELIST=127.0.0.1
# FEEDBACK_IP_WHITELIST=127.0.0.1

# ================================================
# Feedback
# ================================================
# FEEDBACK_MAIL_FROM=your-email@example.com
# FEEDBACK_MAIL_TO=ops@example.com
# FEEDBACK_ATTACHMENTS_DIR=data/feedback-attachments
# FEEDBACK_ATTACHMENT_MAX_SIZE=5242880
# FEEDBACK_MAX_ATTACHMENTS=5

# ================================================
# Usage coach
# Admin-only usage suggestion analysis.
# ================================================
# COACH_SAMPLE_RATE=0.2
# COACH_RETENTION_DAYS=30
# COACH_API_BASE=http://127.0.0.1:3080/relay
# COACH_API_KEY=sk-xxx
# COACH_MODEL=glm-5
# Format: pattern1|||replacement1;;;pattern2|||replacement2
# COACH_SANITIZE_PATTERNS=

# ================================================
# Cluster
# ================================================
# CLUSTER_INTERNAL_SECRET=<a-long-random-secret>
# CLUSTER_BASE_PORT=3081
# CLUSTER_WORKER_COUNT=4

# ================================================
# Deployment helper script
# ================================================
# DEPLOY_HOST=deploy.example.com
# DEPLOY_PORT=22
# DEPLOY_USER=deploy
# DEPLOY_PATH=/home/claude-api-proxy
# DEPLOY_PM2_NAME=ClaudeApiProxy
# DEPLOY_HEALTH_URL=http://localhost:3080/health

# ================================================
# Debug payload interceptor
# Disabled by default. Do not enable in production unless you understand
# the privacy and disk usage impact.
# ================================================
# PAYLOAD_INTERCEPT_ENABLED=false
# PAYLOAD_INTERCEPT_DIR=.debug-payloads
# PAYLOAD_INTERCEPT_MAX_FILES=500
# PAYLOAD_INTERCEPT_PREFIX_CHARS=3000
